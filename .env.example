# Copy to .env.local and fill in your Supabase project values.
# Both fields are safe to expose in the browser — the publishable key is the new public client key
# (replaces the legacy anon JWT key). DO NOT put the secret key (sb_secret_*) here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
